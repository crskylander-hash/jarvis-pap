# ============================================================
# PROJETO JARVIS — variáveis de ambiente (EXEMPLO)
# Copiar os valores reais para os sítios indicados — NUNCA para o GitHub.
# ============================================================

# ---------- BACKEND (colar em backend/.env — local e no PythonAnywhere) ----------
# Chave da API da Anthropic (console.anthropic.com > API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Modelo a usar (não alterar sem motivo)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# URL do projeto Supabase (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key do Supabase (Settings > API > service_role) — SECRETA!
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# URL do frontend na Vercel (para o CORS). Vários domínios separados por vírgula.
FRONTEND_URL=https://jarvis-pap.vercel.app

# ---------- FRONTEND (colar em frontend/.env — local e nas env vars da Vercel) ----------
# URL do projeto Supabase (o mesmo de cima)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Chave PÚBLICA (anon) do Supabase (Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# URL do backend no PythonAnywhere (sem barra no fim)
VITE_BACKEND_URL=https://oteuusername.pythonanywhere.com

# ---------- RPI CLIENT (colar em rpi-client/.env no Raspberry Pi) ----------
# URL do backend (o mesmo de cima)
BACKEND_URL=https://oteuusername.pythonanywhere.com
